# Resend (메일 발송)
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Google OAuth2 (Gmail API용 - 기존 로그인용 GOOGLE_CLIENT_ID/SECRET과 같은 값을 써도 무방하나,
# scope가 다르므로 별도 OAuth Client를 권장)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Gmail watch() 대상 Pub/Sub 토픽
# 형식: projects/{project-id}/topics/{topic-name}
GOOGLE_PUBSUB_TOPIC=

# Pub/Sub push 구독에 연결한 서비스 계정 이메일 (OIDC 토큰 발급 주체 검증용)
PUBSUB_PUSH_SERVICE_ACCOUNT=

# (선택) Pub/Sub push 구독의 audience를 명시적으로 다르게 설정한 경우에만 지정
# 기본값은 요청이 들어온 origin + /api/gmail-webhook
PUBSUB_PUSH_AUDIENCE=

# /api/gmail-renew-watch 를 외부(Vercel Cron)에서만 호출하도록 보호하는 시크릿
CRON_SECRET=
